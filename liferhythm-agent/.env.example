# ─── Required ────────────────────────────────────────────────────────────────

# Your Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Google Sheets — the ID from the URL of your sheet
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
LIFERHYTHM_SHEET_ID=

# Path to your liferhythm-mcp server (defaults to ~/liferhythm-mcp)
# MCP_SERVER_PATH=/home/youruser/liferhythm-mcp


# ─── Telegram Bot ─────────────────────────────────────────────────────────────

# Token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your personal chat ID — start the bot and send /start to get this
TELEGRAM_CHAT_ID=


# ─── Email Notifications (optional — skip to use Telegram only) ───────────────

# Option A: Gmail with App Password
#   1. Enable 2-Step Verification on your Google account
#   2. Go to myaccount.google.com/apppasswords → create an app password
EMAIL_FROM=you@gmail.com
EMAIL_TO=you@gmail.com
EMAIL_APP_PASSWORD=

# Option B: Generic SMTP (Outlook, Fastmail, self-hosted, etc.)
#   If SMTP_HOST is set it takes priority over the Gmail config above.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@example.com
# SMTP_PASS=


# ─── Scheduled Notifications ──────────────────────────────────────────────────

# Cron expression for morning briefing (default: 8:00 AM)
# BRIEFING_CRON=0 8 * * *

# Cron expression for evening check-in (default: 8:00 PM)
# CHECKIN_CRON=0 20 * * *
